# Example environment variables for this project
# Copy this file to `.env.local` and fill in real values before running locally.
# NEVER commit real secrets to version control.

# Supabase (set these from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=pk.your_public_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=sk.your_service_role_key_here

# Resend (used for sending reply emails)
RESEND_API_KEY=ssr.your_resend_api_key_here

# Optional: base URL for the app (used by some integrations)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# If you use any other 3rd-party services, add their placeholders here:
# MAIL_FROM=hello@example.com
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Local dev flags
# FORCE_DISABLE_ANALYTICS=true
